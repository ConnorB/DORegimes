```{r}
feature_long <- all_shap$X |>
  select(all_of(selected_vars)) |>
  mutate(id = row_number()) |>
  pivot_longer(
    cols = -id,
    names_to = "feature",
    values_to = "feature_value"
  )
# Convert SHAP list to long tibble
shap_tibble <- map2_dfr(
  all_shap$S,
  names(all_shap$S),
  \(mat, clust) {
    as_tibble(mat) |>
      mutate(across(everything(), as.numeric)) |>
      mutate(id = row_number(), Cluster = clust)
  }
) |>
  pivot_longer(
    cols = -c(id, Cluster),
    names_to = "feature",
    values_to = "shap_value"
  )

shap_tibble <- shap_tibble |>
  left_join(feature_long, by = c("id", "feature")) |> 
  mutate(feature = case_when(
      feature %in% names(var_names) ~ var_names[feature], TRUE ~ feature))

feature_order <- shap_tibble |>
  group_by(feature) |>
  summarise(mean_abs_shap = mean(abs(shap_value), na.rm = TRUE)) |>
  arrange(desc(mean_abs_shap)) |>
  pull(feature)

library(ggbeeswarm)

shap_tibble |>
  group_by(feature) |>
  mutate(
    feature_value_scaled = (feature_value - min(feature_value, na.rm = TRUE)) /
      (max(feature_value, na.rm = TRUE) - min(feature_value, na.rm = TRUE))
  ) |>
  ungroup() |> 
  mutate(feature = factor(feature, levels = feature_order),
         Cluster = factor(Cluster, levels = c("3", "2", "1"))) |> 
  ggplot(aes(x = shap_value, y = Cluster, color = feature_value_scaled)) +
  geom_quasirandom(groupOnX = FALSE, dodge.width = 1, alpha = 0.2, method = "tukeyDense") +
  scale_color_viridis_c(
    option = "plasma",
    breaks = c(0, 1),
    labels = c("Low", "High")
  ) +
  labs(
    x = "SHAP Value",
    y = "Regime",
    color = "Feature Value",
  ) +
  facet_wrap(~feature, nrow = 2, scales = "free_x") +
  theme(legend.title = element_text(vjust = 1),
        axis.text.x = element_text(angle = 45, hjust = 1)) -> p
