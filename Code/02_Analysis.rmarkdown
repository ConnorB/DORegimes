```{r}

# Find best lag
best_lag <- lag_results |>
  filter(.metric == c("f_meas")) |>
  group_by(variable) |>
  mutate(
         best_mean = max(mean, na.rm = TRUE)) |>
  filter(mean >= best_mean * 0.97) |>
  slice_min(lag, n = 1) |>
  ungroup() |>
  select(-best_mean)

# Lag data
best_lags_data <- lagged_data_scaled |>
  group_by(Site, name) |>
  arrange(Date) |>
  mutate(
    across(
      all_of(best_lag$variable),
      ~ {
        this_lag <- best_lag$lag[best_lag$variable == cur_column()]
        slider::slide_dbl(
          .x,
          mean,
          .before = this_lag,
          .after = 0,
          .complete = FALSE
        )
      },
      .names = "{.col}_lag"
    )
  ) |>
  ungroup()

rename_lagged <- function(df, best_tbl) {
  for (i in seq_len(nrow(best_tbl))) {
    var <- best_tbl$variable[i]
    lagn <- best_tbl$lag[i]
    df <- df |>
      rename("{var}_{lagn}d" := paste0(var, "_lag"))
  }
  df
}

best_lags_data <- rename_lagged(best_lags_data, best_lag)
best_lags_data <- best_lags_data |>
  select(-any_of(best_lag$variable)) |> 
  drop_na(Cluster)

rf_lagged_mod <- fit_full_model(df = best_lags_data, response = "Cluster", label   = "best_lag_model")

final_wf <- rf_lagged_mod$final_wf
final_fit <- rf_lagged_mod$final_fit
fitted_model <- extract_fit_parsnip(final_fit)$fit
train_data <- rf_lagged_mod$train_data
selected_vars <- rf_lagged_mod$selected_vars
beep(2)
```

